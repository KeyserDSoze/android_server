#!/bin/sh
set -eu

printf "Nome tunnel Cloudflare [blade20]: "
read TUNNEL
TUNNEL=${TUNNEL:-blade20}
printf "Hostname pubblico, es. chamber.example.com: "
read HOSTNAME
[ -n "$HOSTNAME" ] || { echo "Hostname richiesto" >&2; exit 1; }

mkdir -p /root/.cloudflared /etc/blade-server

if ! command -v cloudflared >/dev/null 2>&1; then
  echo "cloudflared non trovato. Prova: apk add cloudflared"
  exit 1
fi

cloudflared tunnel login
cloudflared tunnel create "$TUNNEL" || true
CRED="$(find /root/.cloudflared -name '*.json' | head -n 1)"
[ -n "$CRED" ] || { echo "Credenziali tunnel non trovate" >&2; exit 1; }

cat > /root/.cloudflared/config.yml <<CFG
tunnel: $TUNNEL
credentials-file: $CRED

ingress:
  - hostname: $HOSTNAME
    service: http://127.0.0.1:3210
  - service: http_status:404
CFG

printf '%s\n' "$TUNNEL" > /etc/blade-server/tunnel-name
printf '%s\n' "$HOSTNAME" > /etc/blade-server/hostname
cloudflared tunnel route dns "$TUNNEL" "$HOSTNAME" || true
rc-service cloudflared restart || true

echo "Cloudflare configurato: https://$HOSTNAME"
