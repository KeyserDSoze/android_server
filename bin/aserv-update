#!/bin/sh
set -eu

log()  { printf '\n\033[1;32m== %s ==\033[0m\n' "$*"; }
warn() { printf '\n\033[1;33m!! %s\033[0m\n' "$*"; }
ver()  { command -v "$1" >/dev/null 2>&1 && "$1" "$2" 2>/dev/null | head -1 || printf 'not installed\n'; }

log "Alpine packages"
apk update && apk upgrade
printf 'Alpine upgraded.\n'

log "npm global packages"
if command -v npm >/dev/null 2>&1; then
  npm update -g || warn "npm global update failed."
  npm install -g @openchamber/web 2>/dev/null && printf 'openchamber updated\n' || true
else
  printf 'npm not installed — skip.\n'
fi

log "OpenCode"
_oc_arch="$(uname -m)"
case "$_oc_arch" in aarch64|arm64) _oc_arch="arm64" ;; *) _oc_arch="x64" ;; esac
if [ -f /etc/alpine-release ] || (ldd --version 2>&1 | grep -q musl 2>/dev/null); then
  _oc_url="https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-${_oc_arch}-musl.tar.gz"
  curl -fL "$_oc_url" -o /tmp/opencode.tar.gz 2>/dev/null \
    && tar -xzf /tmp/opencode.tar.gz -C /tmp 2>/dev/null \
    && install -m 755 /tmp/opencode /usr/local/bin/opencode \
    && printf 'opencode updated (musl binary)\n' || warn "opencode musl update failed."
  rm -f /tmp/opencode.tar.gz /tmp/opencode
else
  npm install -g opencode 2>/dev/null || npm install -g opencode-ai 2>/dev/null || true
fi

log "Azure CLI"
if command -v az-native >/dev/null 2>&1; then
  /opt/azcli/bin/pip install --upgrade azure-cli \
    && printf 'Azure CLI: %s\n' "$(az version 2>/dev/null | head -1 || echo updated)" \
    || warn "Azure CLI update failed."
elif command -v az >/dev/null 2>&1; then
  printf 'az available (Docker-based or system): %s\n' "$(az version 2>/dev/null | head -1 || echo ok)"
else
  printf 'az not installed — skip.\n'
fi

log "GitHub CLI extensions"
if command -v gh >/dev/null 2>&1; then
  gh extension upgrade --all || warn "gh extension upgrade failed."
  printf 'gh: %s\n' "$(ver gh --version)"
else
  printf 'gh not installed — skip.\n'
fi

log "Cloudflared"
if command -v cloudflared >/dev/null 2>&1; then
  # Try apk first; if it fails the binary was installed manually → re-download
  if ! apk upgrade cloudflared 2>/dev/null; then
    _cf_arch="$(uname -m)"
    case "$_cf_arch" in
      aarch64|arm64) _cf_arch="arm64" ;;
      armv7*)        _cf_arch="arm"   ;;
      *)             _cf_arch="amd64" ;;
    esac
    curl -fsSL \
      "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${_cf_arch}" \
      -o /usr/local/bin/cloudflared \
      && chmod +x /usr/local/bin/cloudflared \
      && printf 'cloudflared updated: %s\n' "$(cloudflared --version 2>/dev/null || echo ok)" \
      || warn "cloudflared update failed."
  fi
  printf 'cloudflared: %s\n' "$(ver cloudflared --version)"
else
  printf 'cloudflared not installed — skip.\n'
fi

log "Versions after update"
printf '  %-18s %s\n' "node"        "$(ver node --version)"
printf '  %-18s %s\n' "npm"         "$(ver npm --version)"
printf '  %-18s %s\n' "opencode"    "$(ver opencode --version)"
printf '  %-18s %s\n' "openchamber" "$(ver openchamber --version)"
printf '  %-18s %s\n' "cloudflared" "$(ver cloudflared --version)"
printf '  %-18s %s\n' "gh"          "$(ver gh --version)"
printf '  %-18s %s\n' "dotnet"      "$(ver dotnet --version)"
printf '  %-18s %s\n' "az"          "$(ver az version)"

log "Update complete"

