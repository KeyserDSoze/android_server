#!/bin/sh
# aserv-config-build — Encrypt a configsrc/ profile into config/
#
# Usage:
#   aserv-config-build <configsrc/profile.conf>
#
# The source .conf file must define CONFIG_NAME and CONFIG_PASSWORD.
# Encryption: AES-256-CBC + PBKDF2, 600 000 iterations, random salt.
# Output:     config/<CONFIG_NAME>.enc  (safe to commit to git)
#
# See docs/secrets-config.md for the full guide.

set -eu

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

die()  { printf '\033[1;31mERROR: %s\033[0m\n' "$*" >&2; exit 1; }
log()  { printf '\033[1;32m>> %s\033[0m\n' "$*"; }
note() { printf '   %s\n' "$*"; }

[ $# -eq 1 ] || die "Usage: aserv-config-build <configsrc/profile.conf>"
SRC="$1"
[ -f "$SRC" ] || die "File not found: $SRC"

# Extract a variable value without eval or shell-sourcing the file.
# Handles: VAR="value", VAR='value', VAR=value
get_value() {
  awk -v key="$1" '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    {
      eqpos = index($0, "=")
      if (eqpos == 0) next
      k = substr($0, 1, eqpos - 1)
      gsub(/[[:space:]]/, "", k)
      if (k != key) next
      v = substr($0, eqpos + 1)
      gsub(/^[[:space:]]*["'"'"']?/, "", v)
      gsub(/["'"'"']?[[:space:]]*$/, "", v)
      print v
      exit
    }
  ' "$2"
}

CONFIG_NAME="$(get_value CONFIG_NAME "$SRC")"
CONFIG_PASSWORD="$(get_value CONFIG_PASSWORD "$SRC")"

[ -n "$CONFIG_NAME" ]     || die "CONFIG_NAME is not defined in $SRC"
[ -n "$CONFIG_PASSWORD" ] || die "CONFIG_PASSWORD is not defined in $SRC"
[ "$CONFIG_PASSWORD" = "change_me_before_encrypting" ] && \
  die "Set a real CONFIG_PASSWORD in $SRC before running aserv-config-build."

OUT_DIR="$BASE_DIR/config"
OUT="$OUT_DIR/${CONFIG_NAME}.enc"
mkdir -p "$OUT_DIR"

log "Source  : $SRC"
log "Profile : $CONFIG_NAME"
log "Output  : config/${CONFIG_NAME}.enc"
note "Encrypting with AES-256-CBC + PBKDF2 (600 000 iterations) ..."

openssl enc -aes-256-cbc -pbkdf2 -iter 600000 -salt \
  -in  "$SRC" \
  -out "$OUT" \
  -pass "pass:${CONFIG_PASSWORD}"

log "Done."
note ""
note "config/${CONFIG_NAME}.enc is encrypted and ready."
note "You can safely commit it to git:"
note ""
note "  git add config/${CONFIG_NAME}.enc"
note "  git commit -m 'Add encrypted config profile'"
note ""
note "At install time:  sh install.sh  -> select profile -> enter password"
note ""
note "IMPORTANT: configsrc/ is gitignored. Keep your .conf files safe locally."
