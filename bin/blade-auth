#!/bin/sh
set -eu

echo "GitHub auth"
if command -v gh >/dev/null 2>&1; then gh auth login || true; else echo "gh non installato"; fi

echo "Azure auth"
if command -v az >/dev/null 2>&1; then az login || true; else echo "az non installato"; fi

echo "OpenCode: avvia 'opencode' e poi usa /connect per configurare il provider."
